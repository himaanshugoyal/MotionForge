{
  "name": "video-editor-hyperframes-remotion",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "render:hello": "node -e \"fetch('http://localhost:8787/api/render/hello',{method:'POST'}).then(r=>r.json()).then(console.log).catch(e=>{console.error(e);process.exit(1)})\""
  },
  "dependencies": {
    "@hyperframes/player": "^0.6.112",
    "@hyperframes/producer": "^0.7.54",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "gsap": "^3.12.5",
    "hyperframes": "^0.7.54",
    "lucide-react": "^0.395.0",
    "multer": "^2.2.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^10.0.3",
    "vite": "^5.3.1"
  }
}
